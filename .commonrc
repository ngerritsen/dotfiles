# Utilities
exists ()
{
  command -v "$1" >/dev/null 2>&1
}

# Exports
if exists nvim; then
  export EDITOR=nvim
  export VISUAL=nvim
else
  export EDITOR=vim
  export VISUAL=vim
fi

# Path
for dir in "$HOME/.bin" "$HOME/.local/bin" "$HOME/Applications"; do
  [ -d "$dir" ] && PATH="$dir:$PATH"
done

# Rust
if [ -f "$HOME/.cargo/env" ]
then
  source "$HOME/.cargo/env"
fi

# Plain aliases
alias cl="clear"
alias z="zoxide"
alias g="git"
alias y="yarn"
alias pn="pnpm"

# Aliases
alias dot='/usr/bin/git --git-dir=$HOME/.dot/ --work-tree=$HOME'
alias tmx='tmux attach || tmux new -s main'
alias dsa='docker stop $(docker ps -q)'
alias nnn='nnn -dH'

function gremote()
{
  local url="$(git remote get-url origin)"
  if exists open; then
    open "$url"
  elif exists xdg-open; then
    xdg-open "$url"
  else
    echo "$url"
  fi
}

# Better ls
if exists eza
then
  alias ls='eza --group-directories-first --icons'
  alias ll='ls -lha --git'
fi

# Better file viewer
if exists bat
then
  export BAT_THEME="ansi"
  alias cat='bat'
fi

# Better disk space analyzer
if exists ncdu
then
  alias du="ncdu --color dark -rr -x --exclude .git --exclude node_modules"
fi

# Better ping
if exists prettyping
then
  alias ping='prettyping --nolegend'
fi

# Better vim
if exists nvim
then
  alias v="nvim"
else
  alias v="vim"
fi

# Fastfetch
if exists fastfetch
then
  fastfetch
fi
